# ── Secrets ────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_key_here

# ── LLM Model ─────────────────────────────────────────────────────────
# Groq-hosted model. Change this to swap the inference backend without
# touching code. See https://console.groq.com/docs/models for options.
GROQ_MODEL=openai/gpt-oss-120b

# ── Embedding Model ───────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Chunking ──────────────────────────────────────────────────────────
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ── Retrieval ─────────────────────────────────────────────────────────
TOP_K=5

# ── Upload ────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
